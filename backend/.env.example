# FieldVision AI backend
ENVIRONMENT=development
DEBUG=true

# Create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_MODEL=gemini-1.5-flash-latest

# Optional live cricket provider.
# Without this key, the platform uses production-safe mock data.
CRICKET_DATA_PROVIDER=auto
CRICAPI_KEY=replace_with_your_cricketdata_key
CRICAPI_BASE_URL=https://api.cricapi.com/v1
CRICKET_SERIES_FILTER=ipl,indian premier league,t20

# Local server
HOST=127.0.0.1
PORT=8000

# Comma-separated frontend origins allowed to call the API.
# Production example: https://your-fieldvision-app.vercel.app
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
